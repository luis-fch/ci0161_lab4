# Public app config — embedded in the JS bundle. Never put secrets here.

# Backend base URL.
#   iOS simulator:    http://localhost:3000
#   Android emulator: http://10.0.2.2:3000
#   Physical device:  your machine's LAN IP (e.g. http://192.168.1.50:3000) or a deployed URL
EXPO_PUBLIC_API_URL=http://localhost:3000

# Public OAuth client IDs (safe to embed; the matching secrets live only on the backend).
EXPO_PUBLIC_DISCORD_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
